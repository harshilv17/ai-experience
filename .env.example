# .env.example — Copy to .env.local and fill in your real values

# Required: OpenAI API Key (used for Whisper, GPT-4o, and DALL-E 3)
OPENAI_API_KEY=sk-your-openai-key-here

# Audio pipeline tuning
CHUNK_DURATION_MS=30000
MIN_SPEECH_SECONDS=6
IMAGE_RATE_LIMIT_MS=20000

# Reliability
MAX_API_RETRIES=2
RETRY_BACKOFF_MS=2000

# Paths
CACHE_DIR=/tmp/ai-exp-cache
FALLBACK_IMAGE_DIR=public/fallback

# UI
ENABLE_EMOTION_OVERLAY=true
OVERLAY_DURATION_MS=3000
PROFANITY_FILTER=true
