# .env.example — copy to .env.local and fill in real values

# Required: OpenAI
OPENAI_API_KEY=sk-proj-replace-me

# Optional: use Stability AI for image generation instead of DALL-E 3
STABILITY_API_KEY=sk-replace-me
IMAGE_PROVIDER=dalle3                   # Options: "dalle3" | "stability"

# Audio pipeline tuning
CHUNK_DURATION_MS=30000                 # How long each audio chunk is (ms)
MIN_SPEECH_SECONDS=6                    # Skip cycle if speech < this
IMAGE_RATE_LIMIT_MS=20000               # Minimum ms between image generations

# Reliability
MAX_API_RETRIES=2                       # Retries before triggering fallback
RETRY_BACKOFF_MS=2000                   # Delay between retries

# Paths
CACHE_DIR=/tmp/ai-exp-cache             # Where generated images are cached locally
FALLBACK_IMAGE_DIR=public/fallback      # Where pre-seeded fallback images live

# UI
ENABLE_EMOTION_OVERLAY=true             # Show emotion/keyword overlay after image change
OVERLAY_DURATION_MS=3000                # How long overlay stays visible (ms)
PROFANITY_FILTER=true                   # Filter unsafe content
